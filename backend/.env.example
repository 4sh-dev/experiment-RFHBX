# Database
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# Rails
RAILS_ENV=development
RAILS_MAX_THREADS=5

# Redis
REDIS_URL=redis://redis:6379/0

# ---------------------------------------------------------------------------
# Dev auth bypass (development only)
# Set DEV_AUTH_BYPASS=true to skip OIDC and auto-authenticate as the seeded
# dev user (dev@mordors-edge.local) without a running OIDC provider.
# NEVER set this in production or test — the guard will log an error and
# ignore the flag if it is set outside development.
# ---------------------------------------------------------------------------
DEV_AUTH_BYPASS=false
